{
  "name": "newspapper",
  "version": "1.0.0",
  "description": "Personal news aggregation and summarization tool that generates Instagram-ready slides",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "scrape": "tsx src/index.ts scrape",
    "group": "tsx src/index.ts group",
    "extract-entities": "tsx src/index.ts extract-entities",
    "query-entities": "tsx src/index.ts query-entities",
    "summarize": "tsx src/index.ts summarize",
    "generate": "tsx src/index.ts generate",
    "export": "tsx src/index.ts export",
    "clean": "tsx src/index.ts clean",
    "list": "tsx src/index.ts list",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "news",
    "aggregator",
    "summarization",
    "scraper",
    "nlp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.0.1",
    "axios": "^1.16.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "compromise": "^14.15.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "inquirer": "^13.4.2",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "ml-distance": "^4.0.1",
    "ollama": "^0.6.3",
    "openai": "^6.36.0",
    "ora": "^9.4.0",
    "playwright": "^1.59.1",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  }
}
