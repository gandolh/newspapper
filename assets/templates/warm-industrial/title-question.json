{
  "id": "title-question",
  "theme": "warm-industrial",
  "family": "title",
  "name": "Title — Question",
  "fields": [
    { "key": "text", "label": "Question", "kind": "textarea", "required": true }
  ],
  "sample": {
    "text": "Is this the end of the old order?"
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "flex": 1,
          "justifyContent": "center",
          "gap": "$spacing.md"
        },
        "children": [
          {
            "kind": "text",
            "text": "?",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 800,
              "fontSize": 220,
              "lineHeight": 1,
              "color": "$color.primary"
            }
          },
          {
            "kind": "text",
            "text": "{{text}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 800,
              "fontSize": 64,
              "lineHeight": 1.1,
              "letterSpacing": "-0.02em",
              "color": "$color.on-surface"
            }
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
