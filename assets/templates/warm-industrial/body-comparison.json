{
  "id": "body-comparison",
  "theme": "warm-industrial",
  "family": "body",
  "name": "Body — Comparison",
  "fields": [
    { "key": "heading", "label": "Heading",     "kind": "text", "required": true },
    { "key": "left",    "label": "Left column",  "kind": "pair", "required": true },
    { "key": "right",   "label": "Right column", "kind": "pair", "required": true }
  ],
  "sample": {
    "heading": "Then vs. Now",
    "left":  { "label": "Before", "body": "Rates at historic lows, cheap money drove asset prices sky-high." },
    "right": { "label": "After",  "body": "Rates surging, markets repricing risk, capital flows reversing." }
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "$spacing.md",
          "flex": 1
        },
        "children": [
          {
            "kind": "text",
            "text": "{{heading}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 48,
              "lineHeight": 1.1,
              "letterSpacing": "-0.02em",
              "color": "$color.on-surface"
            }
          },
          {
            "kind": "box",
            "style": {
              "display": "flex",
              "flexDirection": "row",
              "gap": "$spacing.sm",
              "flex": 1
            },
            "children": [
              {
                "kind": "box",
                "style": {
                  "display": "flex",
                  "flexDirection": "column",
                  "flex": 1,
                  "gap": "$spacing.sm",
                  "padding": "$spacing.md",
                  "backgroundColor": "$color.surface-container",
                  "borderRadius": "16px"
                },
                "children": [
                  {
                    "kind": "text",
                    "text": "{{left.label}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 700,
                      "fontSize": 18,
                      "letterSpacing": "0.1em",
                      "textTransform": "uppercase",
                      "color": "$color.on-surface"
                    }
                  },
                  {
                    "kind": "text",
                    "text": "{{left.body}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 400,
                      "fontSize": 26,
                      "lineHeight": 1.4,
                      "color": "$color.on-surface"
                    }
                  }
                ]
              },
              {
                "kind": "box",
                "style": {
                  "display": "flex",
                  "flexDirection": "column",
                  "flex": 1,
                  "gap": "$spacing.sm",
                  "padding": "$spacing.md",
                  "backgroundColor": "$color.primary",
                  "borderRadius": "16px"
                },
                "children": [
                  {
                    "kind": "text",
                    "text": "{{right.label}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 700,
                      "fontSize": 18,
                      "letterSpacing": "0.1em",
                      "textTransform": "uppercase",
                      "color": "$color.on-primary"
                    }
                  },
                  {
                    "kind": "text",
                    "text": "{{right.body}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 400,
                      "fontSize": 26,
                      "lineHeight": 1.4,
                      "color": "$color.on-primary"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
