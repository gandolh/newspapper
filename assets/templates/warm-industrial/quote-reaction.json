{
  "id": "quote-reaction",
  "theme": "warm-industrial",
  "family": "quote",
  "name": "Quote — Reaction",
  "fields": [
    { "key": "quote",       "label": "Quote text",  "kind": "textarea", "required": true },
    { "key": "attribution", "label": "Attribution", "kind": "text",     "required": true }
  ],
  "sample": {
    "quote": "This is unprecedented in modern financial history.",
    "attribution": "Former Fed Chair"
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.primary",
      "color": "$color.on-primary",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "flex": 1,
          "justifyContent": "center",
          "gap": "$spacing.md"
        },
        "children": [
          {
            "kind": "text",
            "text": "“{{quote}}”",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 800,
              "fontSize": 64,
              "lineHeight": 1.15,
              "letterSpacing": "-0.02em",
              "color": "$color.on-primary"
            }
          },
          {
            "kind": "text",
            "text": "— {{attribution}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 22,
              "letterSpacing": "0.1em",
              "textTransform": "uppercase",
              "color": "$color.on-primary",
              "opacity": 0.85
            }
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-primary",
          "opacity": 0.7,
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
