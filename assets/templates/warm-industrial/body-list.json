{
  "id": "body-list",
  "theme": "warm-industrial",
  "family": "body",
  "name": "Body — List",
  "fields": [
    { "key": "heading", "label": "Heading", "kind": "text", "required": true },
    { "key": "items",   "label": "Items",   "kind": "list", "required": true }
  ],
  "sample": {
    "heading": "Key Takeaways",
    "items": [
      "Central banks raised rates for the sixth time this year",
      "Inflation remains above target in most G7 nations",
      "Energy prices are expected to fall through winter"
    ]
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "$spacing.md",
          "marginTop": "$spacing.md"
        },
        "children": [
          {
            "kind": "text",
            "text": "{{heading}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 52,
              "lineHeight": 1.1,
              "letterSpacing": "-0.02em",
              "color": "$color.on-surface"
            }
          },
          {
            "kind": "repeat",
            "source": "items",
            "style": {
              "display": "flex",
              "flexDirection": "column",
              "gap": "$spacing.sm"
            },
            "children": [
              {
                "kind": "box",
                "style": {
                  "display": "flex",
                  "flexDirection": "row",
                  "gap": "$spacing.sm",
                  "alignItems": "flex-start"
                },
                "children": [
                  {
                    "kind": "text",
                    "text": "{{i}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 800,
                      "fontSize": 28,
                      "color": "$color.primary",
                      "minWidth": "48px"
                    }
                  },
                  {
                    "kind": "text",
                    "text": "{{item}}",
                    "style": {
                      "display": "flex",
                      "fontFamily": "'Inter', sans-serif",
                      "fontWeight": 400,
                      "fontSize": 28,
                      "lineHeight": 1.4,
                      "color": "$color.on-surface",
                      "flex": 1
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
