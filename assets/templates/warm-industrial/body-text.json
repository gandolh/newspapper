{
  "id": "body-text",
  "theme": "warm-industrial",
  "family": "body",
  "name": "Body — Text",
  "fields": [
    { "key": "heading", "label": "Heading", "kind": "text",     "required": true },
    { "key": "body",    "label": "Body",    "kind": "textarea", "required": true }
  ],
  "sample": {
    "heading": "Context Matters",
    "body": "Economists warn that inflation pressures remain high despite recent rate hikes, with supply chains still recovering from the pandemic shock."
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "$spacing.md",
          "marginTop": "$spacing.md"
        },
        "children": [
          {
            "kind": "text",
            "text": "{{heading}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 56,
              "lineHeight": 1.1,
              "letterSpacing": "-0.02em",
              "color": "$color.on-surface"
            }
          },
          {
            "kind": "text",
            "text": "{{body}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 400,
              "fontSize": 32,
              "lineHeight": 1.45,
              "color": "$color.on-surface-variant"
            }
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
