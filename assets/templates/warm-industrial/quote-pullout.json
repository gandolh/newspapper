{
  "id": "quote-pullout",
  "theme": "warm-industrial",
  "family": "quote",
  "name": "Quote — Pullout",
  "fields": [
    { "key": "quote",       "label": "Quote text",  "kind": "textarea", "required": true },
    { "key": "attribution", "label": "Attribution", "kind": "text",     "required": true }
  ],
  "sample": {
    "quote": "We are at an inflection point in history.",
    "attribution": "UN Secretary-General"
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface-container",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "flex": 1,
          "justifyContent": "center",
          "gap": "$spacing.sm"
        },
        "children": [
          {
            "kind": "text",
            "text": "“",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 260,
              "lineHeight": 0.8,
              "color": "$color.primary",
              "marginBottom": "-40px"
            }
          },
          {
            "kind": "text",
            "text": "{{quote}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 600,
              "fontSize": 56,
              "lineHeight": 1.2,
              "color": "$color.on-surface"
            }
          },
          {
            "kind": "text",
            "text": "— {{attribution}}",
            "style": {
              "display": "flex",
              "marginTop": "$spacing.md",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 700,
              "fontSize": 22,
              "color": "$color.on-surface-variant"
            }
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
