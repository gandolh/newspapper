{
  "id": "title-main",
  "theme": "warm-industrial",
  "family": "title",
  "name": "Title — Main",
  "fields": [
    { "key": "text",   "label": "Headline",  "kind": "textarea", "required": true  },
    { "key": "kicker", "label": "Kicker",    "kind": "text",     "required": false }
  ],
  "sample": {
    "text": "Big News Today",
    "kicker": "Breaking"
  },
  "root": {
    "kind": "box",
    "style": {
      "width": 1080,
      "height": 1080,
      "display": "flex",
      "flexDirection": "column",
      "backgroundColor": "$color.surface",
      "color": "$color.on-surface",
      "padding": "$spacing.xl",
      "fontFamily": "'Inter', sans-serif"
    },
    "children": [
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "gap": "$spacing.md",
          "marginTop": "$spacing.xl"
        },
        "children": [
          {
            "kind": "text",
            "text": "{{kicker}}",
            "style": {
              "display": "flex",
              "alignSelf": "flex-start",
              "padding": "4px 12px",
              "backgroundColor": "$color.primary",
              "color": "$color.on-primary",
              "fontFamily": "'Inter', sans-serif",
              "fontSize": 18,
              "fontWeight": 700,
              "letterSpacing": "0.08em",
              "textTransform": "uppercase",
              "borderRadius": "8px"
            }
          },
          {
            "kind": "text",
            "text": "{{text}}",
            "style": {
              "display": "flex",
              "fontFamily": "'Inter', sans-serif",
              "fontWeight": 800,
              "fontSize": 92,
              "lineHeight": 1.0,
              "letterSpacing": "-0.04em",
              "color": "$color.on-surface"
            }
          }
        ]
      },
      {
        "kind": "box",
        "style": {
          "display": "flex",
          "flexDirection": "row",
          "justifyContent": "space-between",
          "alignItems": "center",
          "marginTop": "auto",
          "paddingTop": "$spacing.md",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": 14,
          "fontWeight": 700,
          "color": "$color.on-surface-variant",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "children": [
          { "kind": "text", "text": "Newspapper" },
          { "kind": "text", "text": "{{_index}} / {{_total}}" }
        ]
      }
    ]
  }
}
