# Ollama — start with: docker compose --profile ollama up -d (newspaper-infra/)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_API_KEY=

# Scraping
USER_AGENT=Newspapper/2.0
REQUEST_TIMEOUT=30000
MAX_RETRIES=3

# Image generation
IMAGE_FORMAT=png
IMAGE_QUALITY=90

# Data retention
DEFAULT_RETENTION_DAYS=30
