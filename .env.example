# Ollama — local (default): run `ollama serve` or `docker compose --profile ollama up -d`
OLLAMA_HOST=http://localhost:11434
# OLLAMA_API_KEY=   # required only for Ollama Cloud (OLLAMA_HOST=https://ollama.com)
OLLAMA_MODEL=llama3.2:1b

# API server port (default 3001)
PORT=3001

# Optional overrides
# THEME=warm-industrial
# NEWSPAPPER_DB_PATH=./data/newspapper.db
