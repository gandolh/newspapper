# Ollama — start with: docker compose -f newspaper-infra/docker-compose.yml up -d
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Scrape
MAX_ARTICLES_PER_SOURCE=5
USER_AGENT=Newspapper/2.0
REQUEST_TIMEOUT=30000
MAX_RETRIES=3

# Render
THEME=warm-industrial
OUTPUT_DIR=./output

# Storage
DB_PATH=./data/newspapper.db
DEFAULT_RETENTION_DAYS=30
