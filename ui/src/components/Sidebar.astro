---
/**
 * Sidebar — the single navigation rail shared by every page (wizard pages via
 * App.astro and the full-screen builder via builder.astro). One source of truth
 * for the nav links, icons, brand, and styling.
 *
 * Icons are a coherent Lucide (ISC) set: all 24×24, stroke-only, currentColor,
 * uniform 2px stroke. `transition:persist` keeps this rail mounted across view
 * transitions so it never flashes or re-runs the health-dot island.
 */
import ApiHealthDot from './ApiHealthDot';

const navLinks = [
  {
    href: '/',
    label: 'Create',
    icon: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/>',
  },
  {
    href: '/history',
    label: 'History',
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  },
  {
    href: '/sources',
    label: 'Sources',
    icon: '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>',
  },
  {
    href: '/builder',
    label: 'Templates',
    icon: '<rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/>',
  },
  {
    href: '/prompt',
    label: 'Prompt',
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M7 9h10"/><path d="M7 13h6"/>',
  },
  {
    href: '/settings',
    label: 'Settings',
    icon: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
  },
];

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<nav class="sidebar" aria-label="Main navigation" transition:persist="sidebar">
  <div class="sidebar-brand">
    <a href="/" class="brand-link" aria-label="newspapper home">
      <span class="brand-mark">np</span>
      <span class="brand-name">newspapper</span>
    </a>
  </div>

  <ul class="nav-list" role="list">
    {navLinks.map(({ href, label, icon }) => (
      <li>
        <a
          href={href}
          class:list={['nav-item', { 'nav-item--active': isActive(href) }]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          <svg
            class="nav-icon"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={icon}
          />
          <span class="nav-label">{label}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="sidebar-footer">
    <ApiHealthDot client:load />
  </div>
</nav>

<style>
  .sidebar {
    width: var(--sidebar-width);
    min-height: 100vh;
    background: var(--surface-card);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-brand {
    padding: var(--sp-md) var(--sp-sm);
    border-bottom: 1px solid var(--border);
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--on-surface);
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--primary);
    color: var(--on-primary);
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: -0.04em;
    flex-shrink: 0;
  }

  .brand-name {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--on-surface);
  }

  .nav-list {
    flex: 1;
    padding: var(--sp-sm) var(--sp-xs);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    height: var(--nav-item-height);
    padding: 0 var(--sp-sm);
    border-radius: var(--radius);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    position: relative;
  }

  .nav-item:hover {
    background: var(--surface-low);
    color: var(--on-surface);
  }

  .nav-item--active {
    background: var(--primary-soft);
    color: var(--primary);
    font-weight: 600;
  }

  .nav-item--active:hover {
    background: var(--primary-soft-hover);
    color: var(--primary-hover);
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .nav-label {
    flex: 1;
  }

  .sidebar-footer {
    padding: var(--sp-sm);
    border-top: 1px solid var(--border);
  }

  /* Below the tablet breakpoint, collapse to an icon rail. */
  @media (max-width: 768px) {
    .sidebar {
      width: 60px;
    }
    .sidebar-brand {
      padding: var(--sp-md) 0;
      display: flex;
      justify-content: center;
    }
    .brand-name {
      display: none;
    }
    .nav-list {
      padding: var(--sp-sm) 8px;
    }
    .nav-item {
      justify-content: center;
      padding: 0;
    }
    .nav-label {
      display: none;
    }
    .sidebar-footer {
      display: flex;
      justify-content: center;
      padding: var(--sp-sm) 0;
    }
  }
</style>
