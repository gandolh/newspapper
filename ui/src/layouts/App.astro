---
import '../styles/global.css';
import ApiHealthDot from '../components/ApiHealthDot';

const { title = 'newspapper', width = 'default' } = Astro.props;
const path = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Create', icon: '✦' },
  { href: '/history', label: 'History', icon: '◷' },
  { href: '/sources', label: 'Sources', icon: '⊕' },
  { href: '/builder', label: 'Templates', icon: '▦' },
  { href: '/prompt', label: 'Prompt', icon: '≡' },
  { href: '/settings', label: 'Settings', icon: '⚙' },
];

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} — newspapper</title>
  </head>
  <body>
    <div class="app-shell">
      <!-- Left sidebar nav -->
      <nav class="sidebar" aria-label="Main navigation">
        <div class="sidebar-brand">
          <a href="/" class="brand-link" aria-label="newspapper home">
            <span class="brand-mark">np</span>
            <span class="brand-name">newspapper</span>
          </a>
        </div>

        <ul class="nav-list" role="list">
          {navLinks.map(({ href, label, icon }) => (
            <li>
              <a
                href={href}
                class:list={['nav-item', { 'nav-item--active': isActive(href) }]}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                <span class="nav-icon" aria-hidden="true">{icon}</span>
                <span class="nav-label">{label}</span>
              </a>
            </li>
          ))}
        </ul>

        <div class="sidebar-footer">
          <ApiHealthDot client:load />
        </div>
      </nav>

      <!-- Main content area -->
      <main class="main-content">
        <div class:list={['content-wrap', { 'content-wrap--fluid': width === 'fluid' }]}>
          <slot />
        </div>
      </main>
    </div>

    <style>
      .app-shell {
        display: flex;
        min-height: 100vh;
        background: var(--surface);
      }

      /* ---- Sidebar ---- */
      .sidebar {
        width: var(--sidebar-width);
        min-height: 100vh;
        background: var(--surface-card);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }

      /* Brand wordmark */
      .sidebar-brand {
        padding: var(--sp-md) var(--sp-sm);
        border-bottom: 1px solid var(--border);
      }

      .brand-link {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--on-surface);
      }

      .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--primary);
        color: var(--on-primary);
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: -0.04em;
        flex-shrink: 0;
      }

      .brand-name {
        font-size: 15px;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--on-surface);
      }

      /* Nav list */
      .nav-list {
        flex: 1;
        padding: var(--sp-sm) var(--sp-xs);
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        height: var(--nav-item-height);
        padding: 0 var(--sp-sm);
        border-radius: var(--radius);
        font-size: var(--font-size-sm);
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: background 0.15s ease, color 0.15s ease;
        position: relative;
      }

      .nav-item:hover {
        background: var(--surface-low);
        color: var(--on-surface);
      }

      .nav-item--active {
        background: var(--primary-soft);
        color: var(--primary);
        font-weight: 600;
      }

      .nav-item--active:hover {
        background: var(--primary-soft-hover);
        color: var(--primary-hover);
      }

      .nav-icon {
        font-size: 14px;
        width: 18px;
        text-align: center;
        flex-shrink: 0;
        opacity: 0.8;
      }

      .nav-label {
        flex: 1;
      }

      /* Sidebar footer */
      .sidebar-footer {
        padding: var(--sp-sm);
        border-top: 1px solid var(--border);
      }

      /* ---- Main content ---- */
      .main-content {
        flex: 1;
        min-width: 0;
        overflow-y: auto;
        padding: var(--sp-md) var(--sp-container);
      }

      /* Centered content column. Default pages (lists, forms) sit in a
         deliberate max-width column with balanced gutters; fluid pages
         (wizard, builder) take the full available width. */
      .content-wrap {
        max-width: var(--content-max);
        margin-inline: auto;
      }

      .content-wrap--fluid {
        max-width: none;
      }

      /* ---- Responsive: collapse the sidebar to an icon rail ----
         This is a desktop tool; below the tablet breakpoint we reclaim
         horizontal space rather than building a separate mobile shell. */
      @media (max-width: 768px) {
        .sidebar {
          width: 60px;
        }
        .sidebar-brand {
          padding: var(--sp-md) 0;
          display: flex;
          justify-content: center;
        }
        .brand-name {
          display: none;
        }
        .nav-list {
          padding: var(--sp-sm) 8px;
        }
        .nav-item {
          justify-content: center;
          padding: 0;
        }
        .nav-label {
          display: none;
        }
        .sidebar-footer {
          display: flex;
          justify-content: center;
          padding: var(--sp-sm) 0;
        }
        .main-content {
          padding: var(--sp-md) var(--sp-sm);
        }
      }
    </style>
  </body>
</html>
