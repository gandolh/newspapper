---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';

const { title = 'newspapper', width = 'default' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} — newspapper</title>
    <ClientRouter />
  </head>
  <body>
    <div class="app-shell">
      <!-- Left sidebar nav (shared across all pages) -->
      <Sidebar />

      <!-- Main content area -->
      <main class="main-content">
        <div
          class:list={['content-wrap', { 'content-wrap--fluid': width === 'fluid' }]}
          transition:animate="fade"
        >
          <slot />
        </div>
      </main>
    </div>

    <style>
      .app-shell {
        display: flex;
        min-height: 100vh;
        background: var(--surface);
      }

      /* ---- Main content ---- */
      .main-content {
        flex: 1;
        min-width: 0;
        overflow-y: auto;
        padding: var(--sp-md) var(--sp-container);
      }

      /* Centered content column. Default pages (lists, forms) sit in a
         deliberate max-width column with balanced gutters; fluid pages
         (wizard, builder) take the full available width. */
      .content-wrap {
        max-width: var(--content-max);
        margin-inline: auto;
      }

      .content-wrap--fluid {
        max-width: none;
      }

      @media (max-width: 768px) {
        .main-content {
          padding: var(--sp-md) var(--sp-sm);
        }
      }
    </style>
  </body>
</html>
