---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import BuilderIsland from '../components/builder/BuilderIsland';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Template Builder — newspapper</title>
    <ClientRouter />
  </head>
  <body style="margin:0; overflow: hidden;">
    <div style="display:flex; height:100vh; overflow:hidden;">
      <!-- Shared sidebar nav -->
      <Sidebar />

      <!-- Builder takes up the rest -->
      <div style="flex:1; overflow:hidden; min-width:0;" transition:animate="fade">
        <BuilderIsland client:load />
      </div>
    </div>
  </body>
</html>
