[
  {
    "id": "example-source",
    "name": "Example News Source",
    "url": "https://example.com",
    "rss": "https://example.com/rss",
    "scraperType": "http",
    "selectors": {
      "title": "h1.headline",
      "author": ".author-name",
      "date": "time[datetime]",
      "body": "article .content",
      "image": "meta[property='og:image']"
    },
    "enabled": false
  },
  {
    "id": "rss-source",
    "name": "RSS Feed Source",
    "url": "https://news-site.com/",
    "rss": "https://news-site.com/feed",
    "scraperType": "rss",
    "selectors": {
      "title": "h1.entry-title",
      "author": ".author",
      "date": "time[datetime]",
      "body": ".entry-content",
      "image": "meta[property='og:image']"
    },
    "enabled": false
  },
  {
    "id": "playwright-source",
    "name": "JS-heavy Site (Playwright)",
    "url": "https://js-heavy-site.com/",
    "rss": null,
    "scraperType": "playwright",
    "selectors": {
      "title": "h1",
      "author": null,
